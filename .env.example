# Copy to .env for docker compose. Generate secrets with e.g.:
#   openssl rand -hex 32     # EGRET_NEST_SECRET_KEY (32 bytes)
#   openssl rand -base64 32  # EGRET_NEST_METRICS_TOKEN / EGRET_NEST_WEBHOOK_SECRET

# Image tag to run. Pin a specific released tag for reproducible deploys. The
# floating tags ("latest", "v0", "v0.1", "dev") are a convenience only - they move
# under you and are not for pinned/reproducible deployments.
EGRET_NEST_VERSION=v0.1.1

# Host bind for the dashboard port. Keep it on loopback when behind nginx (tls
# profile); use 0.0.0.0:8080 to expose the bare dashboard directly.
EGRET_NEST_BIND=127.0.0.1:8080

EGRET_NEST_INSTANCE=Egret Nest

# --- Behind the nginx TLS proxy (docker compose --profile tls) ---
# Set these to 1 / your URL so the app issues Secure + __Host- cookies.
EGRET_NEST_BEHIND_PROXY=0
EGRET_NEST_BASE_URL=

# --- Secrets (leave blank to disable the feature) ---
# EGRET_NEST_SECRET_KEY encrypts TOTP (2FA) seeds at rest. Without it the server
# refuses to start, UNLESS you explicitly accept plaintext TOTP storage by setting
# EGRET_NEST_ALLOW_PLAINTEXT_TOTP=1 (not recommended).
EGRET_NEST_SECRET_KEY=
EGRET_NEST_ALLOW_PLAINTEXT_TOTP=
EGRET_NEST_WEBHOOK_SECRET=
EGRET_NEST_METRICS_TOKEN=
EGRET_NEST_RETENTION_DAYS=0

# --- SSO (optional) ---
EGRET_NEST_GITHUB_CLIENT_ID=
EGRET_NEST_GITHUB_CLIENT_SECRET=
EGRET_NEST_GITHUB_ALLOWED_ORG=
EGRET_NEST_OIDC_ISSUER=
EGRET_NEST_OIDC_CLIENT_ID=
EGRET_NEST_OIDC_CLIENT_SECRET=
EGRET_NEST_OIDC_ALLOWED_DOMAIN=
